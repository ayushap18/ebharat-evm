NODE_ENV=development
PORT=8080
API_PORT=8081
CLIENT_ORIGIN=http://localhost:8080

# Use Neon pooled URL or Supabase Postgres URL. Leave empty for local JSON fallback.
DATABASE_URL=
DIRECT_DATABASE_URL=

JWT_ACCESS_SECRET=replace-with-32-byte-minimum-secret
JWT_REFRESH_SECRET=replace-with-32-byte-minimum-secret
DEMO_ADMIN_EMAIL=admin@ebharat.local
DEMO_ADMIN_PASSWORD=Admin@12345

# Optional Supabase Auth client mode
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
